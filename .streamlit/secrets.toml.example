# 复制到 Streamlit Cloud 的 Secrets，不要提交真实 token。

[github]
token = "github_pat_xxxxxxxxxxxxxxxxx"
repo = "Pan-gao-1219/score-systeam"
branch = "main"
scores_path = "data/scores.json"

[app]
admin_password = "请改成你自己的管理员密码"

# ── 阿里云短信（vote_app.py 投票验证码） ──────────────────────────────────────
# 1. 登录 https://ram.console.aliyun.com 创建子用户，授予 AliyunDysmsFullAccess 权限
# 2. 创建 AccessKey，填入下方
# 3. 在短信控制台 https://dysms.console.aliyun.com 申请：
#    - 签名（sign_name）：如"地质模型大赛"，需审核（约 2 小时）
#    - 模板（template_code）：如"SMS_xxxxxxx"，模板内容示例：
#      【${sign_name}】您的投票验证码为${code}，5分钟内有效，请勿泄露。
[aliyun]
access_key_id     = "LTAI5t...（你的 AccessKey ID）"
access_key_secret = "xxxxxx...（你的 AccessKey Secret）"
sign_name         = "地质模型大赛"
template_code     = "SMS_xxxxxxxxx"
